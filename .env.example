# TagAI Mini Apps 环境变量配置示例

# ===========================================
# 1inch API Configuration
# ===========================================
# 用于 SwapToken 功能的 DEX 聚合服务
# 申请地址: https://portal.1inch.dev/
# 说明: 如果不配置，将使用 Mock 环境（仅用于 UI 测试）
VITE_ONEINCH_API_KEY=

# ===========================================
# Privy Configuration
# ===========================================
# Privy App ID (已配置在代码中)
# VITE_PRIVY_APP_ID=your_privy_app_id

# ===========================================
# RPC Endpoints (可选)
# ===========================================
# 如果需要自定义 RPC 节点，可以配置以下变量
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
# VITE_ETHEREUM_RPC_URL=https://eth.llamarpc.com
# VITE_BASE_RPC_URL=https://mainnet.base.org
# VITE_OPTIMISM_RPC_URL=https://mainnet.optimism.io
# VITE_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ===========================================
# 开发模式配置
# ===========================================
# 强制使用 Mock 环境（即使配置了 API Key）
# VITE_USE_MOCK_QUOTE=true

# 启用调试日志
# VITE_DEBUG=true
