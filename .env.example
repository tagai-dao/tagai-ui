# ============================================
# TagAI UI 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填写实际值
# ⚠️ 警告: 切勿将 .env.local 文件提交到版本控制!

# ============================================
# API 配置
# ============================================
# 后端 API 地址
VITE_API_BASE_URL=http://localhost:9901

# WebSocket 地址
VITE_WS_BASE_URL=ws://localhost:3100

# ============================================
# 1inch DEX 配置
# ============================================
# 申请地址: https://portal.1inch.dev/
# 用于 SwapToken 功能，不配置则使用 Mock 数据
VITE_ONEINCH_API_KEY=

# 强制使用 Mock 环境（用于 UI 开发测试）
# VITE_USE_MOCK_QUOTE=true

# ============================================
# Privy 配置
# ============================================
# Privy App ID
# VITE_PRIVY_APP_ID=your_privy_app_id

# ============================================
# RPC 节点配置 (可选)
# ============================================
# 如果需要自定义 RPC 节点，取消注释并配置
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
# VITE_ETHEREUM_RPC_URL=https://eth.llamarpc.com
# VITE_BASE_RPC_URL=https://mainnet.base.org
# VITE_OPTIMISM_RPC_URL=https://mainnet.optimism.io
# VITE_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ============================================
# 安全配置
# ============================================
# 允许的 CORS origins（逗号分隔）
# VITE_ALLOWED_ORIGINS=https://app.tagai.io,https://miniapp.tagai.io

# ============================================
# 开发调试
# ============================================
# 启用调试日志
# VITE_DEBUG=true
